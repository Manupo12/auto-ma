# ============================================================
# RILO SAS — Plantilla de variables de entorno
# Copia este archivo a .env y rellena con tus valores
# ============================================================

# --- Medifolios ---
MEDIFOLIOS_URL=https://www.server0medifolios.net/
MEDIFOLIOS_USER=
MEDIFOLIOS_PASSWORD=

# --- ARL Positiva ---
POSITIVA_URL=https://positivacuida.positiva.gov.co/cas/login
POSITIVA_USER=
POSITIVA_PASSWORD=

# --- Deepgram ---
DEEPGRAM_API_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Gmail ---
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- Directorios ---
STORAGE_DIR=./storage
TEMPLATES_DIR=./templates/formatos
WORKSPACE_DIR=/mnt/c/Users/Sandra/Desktop/SANDRA/ACTIVIDADES OCUPACIONALES
DASHBOARD_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- LLM ---
OPENCODE_GO_API_KEY=
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
LLM_MODEL_EXTRACCION=deepseek-v4-flash
LLM_MODEL_SINTESIS=deepseek-v4-flash

# --- Fase A: pipeline IA + portales ---
FASE_A_ENABLED=false
FASE_A_CRON_ENABLED=false

# --- Playwright ---
PLAYWRIGHT_DEBUG=false
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_SESSIONS_DIR=./storage/playwright_sessions

# --- Tomy Completo ---
TOMY_COMPLETO_ENABLED=true
WORKFLOW_DB_PATH=./storage/workflow.db
WORKFLOW_TIMEOUT_TOTAL_S=1800
AUDIO_CHUNK_DURATION_S=1500
AUDIO_TEMP_DIR=./storage/audios_temp

# --- Auth ---
AUTH_PIN=1234
AUTH_SECRET=cambiar-este-secret-en-prod

# --- Backup ---
BACKUP_HORA=23
BACKUP_DESTINO=./storage/backups

# --- Cron ---
CRON_HORA_NOCHE=21
CRON_COOLDOWN_PACIENTES_S=30
